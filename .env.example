# App environment: development uses local SQLite; production requires Turso/libSQL
APP_ENV=development

# SQLite database file path for local development
DB_PATH=./app.db

# Required: secret key used for signing JWTs (use at least 32 random bytes)
SECRET_KEY=replace-with-at-least-32-random-bytes

# Optional: email that should receive admin role at bootstrap (ADR-006)
ADMIN_EMAIL=admin@example.com

# Optional: public base URL used to build invite links
BASE_URL=

# Production Turso/libSQL settings
# Required when APP_ENV=production
TURSO_DATABASE_URL=libsql://<your-database>.turso.io
TURSO_AUTH_TOKEN=<your-turso-auth-token>
