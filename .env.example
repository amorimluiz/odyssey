# SQLite database file path
DB_PATH=./app.db

# Required: secret key used for signing JWTs (use at least 32 random bytes)
SECRET_KEY=replace-with-at-least-32-random-bytes

# Optional: email that should receive admin role at bootstrap (ADR-006)
ADMIN_EMAIL=admin@example.com

# Optional: Hugging Face Hub persistence for the SQLite file set
HF_TOKEN=
HF_REPO_ID=
HF_REPO_TYPE=dataset
HF_DB_PATH_IN_REPO=app.db
HF_SYNC_ENABLED=true
